@page "/users"
@using TorqERP.ViewModels
@using TorqERP.DataModels
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "ADMIN")]
@inject UsersViewModel VM

<MudText Typo="Typo.h4" Class="mb-4" Color="Color.Primary">User Management</MudText>

<MudTable Items="VM.Users"
          Hover="true"
          Breakpoint="Breakpoint.Sm"
          Loading="VM.IsLoading"
          LoadingProgressColor="Color.Info"
          Filter="new Func<User, bool>(VM.FilterUser)">

    <ToolBarContent>
        <MudText Typo="Typo.h6">System users</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="VM.OpenCreateDialog"
                   Class="mr-4">
            New User
        </MudButton>

        <MudTextField @bind-Value="VM.SearchString"
                      Placeholder="Search by email, username or role"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium"
                      Class="mt-0"
                      Immediate="true" />
    </ToolBarContent>

    <HeaderContent>
        <MudTh>Email</MudTh>
        <MudTh>Username</MudTh>
        <MudTh>Role</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd DataLabel="Email">@context.Email</MudTd>
        <MudTd DataLabel="Username">@context.Username</MudTd>
        <MudTd DataLabel="Role">
            <MudChip T="string"
                     Color="@(context.Role == UserRole.ADMIN ? Color.Error : context.Role == UserRole.MANAGER ? Color.Warning : Color.Info)"
                     Size="Size.Small">
                @context.Role.ToString()
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Actions">
            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                           Color="Color.Error"
                           Size="Size.Small"
                           OnClick="@(() => VM.DeleteUserCommand.ExecuteAsync(context))" />
        </MudTd>
    </RowTemplate>

    <PagerContent>
        <MudTablePager InfoFormat="{first_item}-{last_item} de {all_items}" RowsPerPageString="Rows p page:" />
    </PagerContent>
</MudTable>

<MudDialog @bind-Visible="VM.IsDialogVisible" Options="VM.DialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-3" /> Create New User
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string" Label="Email" @bind-Value="VM.CurrentUser.Email"
                      InputType="InputType.Email" Variant="Variant.Outlined" Class="mb-3" />

        <MudTextField T="string" Label="Username" @bind-Value="VM.CurrentUser.Username"
                      Variant="Variant.Outlined" Class="mb-3" />

        <MudTextField T="string" Label="Password" @bind-Value="VM.CurrentUser.Password"
                      InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-3" />

        <MudSelect T="UserRole" Label="Role" @bind-Value="VM.CurrentUser.Role" Variant="Variant.Outlined">
            @foreach (UserRole role in Enum.GetValues(typeof(UserRole)))
            {
                <MudSelectItem Value="@role">@role.ToString()</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Default" OnClick="VM.CloseDialog" Class="px-10">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="VM.CreateUserCommand.ExecuteAsync" Class="px-10">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    protected override async Task OnInitializedAsync()
    {
        await VM.InitializeCommand.ExecuteAsync(null);
    }
}