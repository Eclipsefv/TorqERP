@page "/workorders"
@using TorqERP.ViewModels
@using TorqERP.DataModels
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject WorkOrdersViewModel VM

<MudText Typo="Typo.h4" Class="mb-4" Color="Color.Primary">Work Orders</MudText>

<MudTable Items="VM.WorkOrders"
          Loading="VM.IsLoading"
          LoadingProgressColor="Color.Info"
          Hover="true"
          Dense="true"
          Breakpoint="Breakpoint.Sm"
          Elevation="1"
          OnRowClick="@((TableRowClickEventArgs<WorkOrder> args) => VM.OnRowClick(args))"
          RowClass="cursor-pointer"
          Filter="new Func<WorkOrder, bool>(VM.FilterWorkOrder)">

    <ToolBarContent>
        <MudText Typo="Typo.h6">Registered Work Orders</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="VM.SearchString"
                      Placeholder="Search by number, description or status"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium"
                      Class="mt-0"
                      Immediate="true" />
        <MudSpacer />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="VM.OpenCreateDialog">
            New Order
        </MudButton>
    </ToolBarContent>

    <HeaderContent>
        <MudTh>Order #</MudTh>
        <MudTh>Description</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Vehicle</MudTh>
        <MudTh>Lines</MudTh>
        <MudTh>Created</MudTh>
        <MudTh>Completed</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd DataLabel="Order #">
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Text" Size="Size.Small">@context.OrderNumber</MudChip>
        </MudTd>
        <MudTd DataLabel="Description">@(context.Description ?? "—")</MudTd>
        <MudTd DataLabel="Status">
            @{
                var (color, label) = WorkOrdersViewModel.GetStatusDisplay(context.Status);
            }
            <MudChip T="string" Color="@color" Variant="Variant.Filled" Size="Size.Small">@label</MudChip>
        </MudTd>
        <MudTd DataLabel="Vehicle">@context.VehicleId</MudTd>
        <MudTd DataLabel="Lines">@context.Lines.Count</MudTd>
        <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</MudTd>
        <MudTd DataLabel="Completed">@(context.CompletedAt.HasValue? context.CompletedAt.Value.ToLocalTime().ToString("dd/MM/yyyy") : "—")</MudTd>
    </RowTemplate>

    <PagerContent>
        <MudTablePager InfoFormat="{first_item}-{last_item} of {all_items}" RowsPerPageString="Rows per page:" />
    </PagerContent>
</MudTable>

<MudDialog @bind-Visible="VM.IsDialogVisible" Options="VM.DialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(VM.IsEditMode? Icons.Material.Filled.Info : Icons.Material.Filled.Build)" Class="mr-3" />
            @(VM.IsEditMode ? $"work order detail: {VM.CurrentWorkOrder.OrderNumber}" : "New work order")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            @if (VM.IsEditMode)
            {
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Order Number" @bind-Value="VM.CurrentWorkOrder.OrderNumber"
                                  Variant="Variant.Outlined" ReadOnly="true" />
                </MudItem>
            }

            <MudItem xs="12" sm="@(VM.IsEditMode ? 6 : 12)">
                @{
                    var (statusColor, statusLabel) = WorkOrdersViewModel.GetStatusDisplay(VM.CurrentWorkOrder.Status);
                }
                <MudTextField T="string" Label="Status" Value="@statusLabel"
                              Variant="Variant.Outlined" ReadOnly="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Circle"
                              AdornmentColor="@statusColor" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField T="string" Label="Description / Fault" @bind-Value="VM.CurrentWorkOrder.Description"
                              Variant="Variant.Outlined" Lines="2" ReadOnly="VM.IsEditMode" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudAutocomplete T="Vehicle"
                                 Label="Select Vehicle"
                                 @bind-Value="VM.SelectedVehicle"
                                 SearchFunc="@VM.SearchVehicles"
                                 ToStringFunc="@(v => v == null ? null : $"{v.Plate} - {v.Model}")"
                                 Variant="Variant.Outlined"
                                 ReadOnly="VM.IsEditMode"
                                 AdornmentIcon="@Icons.Material.Filled.DirectionsCar"
                                 AdornmentColor="Color.Primary">
                    <ItemTemplate Context="vehicle">
                        <MudText>
                            <MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Size="Size.Small" Class="mr-2" />
                            @vehicle.Plate <small class="ml-2" style="color:gray">@vehicle.Brand @vehicle.Model</small>
                        </MudText>
                    </ItemTemplate>
                </MudAutocomplete>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Created At"
                              Value="@VM.CurrentWorkOrder.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")"
                              Variant="Variant.Outlined" ReadOnly="true" />
            </MudItem>
            <MudItem xs="12">
                <div class="d-flex align-center justify-space-between mb-2">
                    <MudText Typo="Typo.subtitle1"><b>Work Lines</b></MudText>
                    <MudButton StartIcon="@Icons.Material.Filled.Add"
                               Size="Size.Small"
                               Variant="Variant.Filled"
                               Color="Color.Secondary"
                               OnClick="VM.AddEmptyLine">
                        Add Line
                    </MudButton>
                </div>

                <MudTable Items="VM.CurrentWorkOrder.Lines" Dense="true" Elevation="0" Outlined="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Product ID</MudTh>
                        <MudTh>Qty</MudTh>
                        <MudTh>Price</MudTh>
                        <MudTh>Disc.</MudTh>
                        <MudTh>Total</MudTh>
                        <MudTh Style="width: 50px"></MudTh>
                    </HeaderContent>
                    <RowTemplate Context="line">
                        <MudTd>
                            @if (line.Id == 0)
                            {
                                <MudNumericField @bind-Value="line.ProductId" Margin="Margin.Dense" Variant="Variant.Text" Min="1" />
                            }
                            else
                            {
                                @line.ProductId
                            }
                        </MudTd>
                        <MudTd>
                            <MudNumericField @bind-Value="line.Quantity" Margin="Margin.Dense" Variant="Variant.Text" Min="0.1f" />
                        </MudTd>
                        <MudTd>
                            <MudNumericField @bind-Value="line.Price" Margin="Margin.Dense" Variant="Variant.Text" Format="N2" />
                        </MudTd>
                        <MudTd>
                            <MudNumericField @bind-Value="line.Discount" Margin="Margin.Dense" Variant="Variant.Text" Format="N2" />
                        </MudTd>
                        <MudTd>
                            @(((decimal)line.Quantity * (line.Price - line.Discount)).ToString("C"))
                        </MudTd>
                        <MudTd>
                            @if (line.Id == 0)
                            {

                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="VM.CloseDialog">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="@(() => VM.SaveWorkOrderCommand.ExecuteAsync(null))" 
                   Disabled="VM.IsLoading">
            @(VM.IsEditMode ? "Update Order" : "Save Order")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    protected override async Task OnInitializedAsync()
    {
        await VM.InitializeCommand.ExecuteAsync(null);
    }
}