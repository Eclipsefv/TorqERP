@page "/inventory"
@using TorqERP.ViewModels
@using TorqERP.DataModels
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject ProductsViewModel VM

<MudText Typo="Typo.h4" Class="mb-4" Color="Color.Primary">Inventory Management</MudText>

<MudTable Items="VM.Products" Hover="true" Breakpoint="Breakpoint.Sm" Loading="VM.IsLoading"
          LoadingProgressColor="Color.Info" Filter="new Func<Product, bool>(VM.FilterProduct)"
          Dense="true" OnRowClick="@((TableRowClickEventArgs<Product> args) => VM.SetupEditMode(args.Item))"
          RowClass="cursor-pointer">

    <ToolBarContent>
        <MudSpacer />
        <MudTextField @bind-Value="VM.SearchString" Placeholder="Search by SKU or Name"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium" Class="mt-0" Immediate="true" />

        <MudText Typo="Typo.h6" Class="ml-4">Product List</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="VM.OpenCreateDialog"
                   StartIcon="@Icons.Material.Filled.Add">
            Add Product
        </MudButton>
    </ToolBarContent>

    <HeaderContent>
        <MudTh>SKU</MudTh>
        <MudTh>Name</MudTh>
        <MudTh>Type</MudTh>
        <MudTh>Sell Price</MudTh>
        <MudTh>Stock</MudTh>
        <MudTh>Location</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd DataLabel="SKU"><b>@context.Sku</b></MudTd>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Type">
            <MudChip T="string" Variant="Variant.Text"
                     Color="@(context.Type == ProductType.SERVICE ? Color.Secondary : Color.Primary)" Size="Size.Small">
                @context.Type.ToString()
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Sell Price">@context.SellPrice.ToString("C", VM.EuroCulture)</MudTd>
        <MudTd DataLabel="Stock">
            @if (context.Stock <= context.MinStock && context.Type == ProductType.ITEM)
            {
                <MudText Color="Color.Error" Typo="Typo.body2"><b>@context.Stock</b> (Low Stock)</MudText>
            }
            else
            {

                @context.Stock
            }
        </MudTd>
        <MudTd DataLabel="Location">@(string.IsNullOrEmpty(context.Location) ? "N/A" : context.Location)</MudTd>
    </RowTemplate>

    <PagerContent>
        <MudTablePager InfoFormat="{first_item}-{last_item} of {all_items}" RowsPerPageString="Rows per page:" />
    </PagerContent>
</MudTable>

@* Dialog *@
<MudDialog @bind-Visible="VM.IsDialogVisible" Options="VM.DialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(VM.IsEditMode? Icons.Material.Filled.Edit : Icons.Material.Filled.AddCircleOutline)" Class="mr-3" />
            @(VM.IsEditMode ? $"Edit Product: {VM.CurrentProduct.Sku}" : "Create Product")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="SKU" @bind-Value="VM.CurrentProduct.Sku" Required="true" Variant="Variant.Outlined" Disabled="VM.IsEditMode" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Name" @bind-Value="VM.CurrentProduct.Name" Required="true" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="ProductType" Label="Type" Variant="Variant.Outlined" @bind-Value="VM.CurrentProduct.Type">
                    @foreach (ProductType type in Enum.GetValues(typeof(ProductType)))
                    {
                        <MudSelectItem Value="@type">@type</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Location" @bind-Value="VM.CurrentProduct.Location" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="VM.CurrentProduct.BuyPrice" Label="Buy Price" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Euro" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="VM.CurrentProduct.SellPrice" Label="Sell Price" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Euro" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="VM.CurrentProduct.TaxRate" Label="Tax %" Variant="Variant.Outlined" Adornment="Adornment.End" AdornmentText="%" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="VM.CurrentProduct.Stock" Label="Stock" Variant="Variant.Outlined" Min="0" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="VM.CurrentProduct.MinStock" Label="Min Stock" Variant="Variant.Outlined" Min="0" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField T="string" Label="Description" @bind-Value="VM.CurrentProduct.Description" Variant="Variant.Outlined" Lines="3" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="VM.CloseDialog">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="VM.SaveProductCommand.ExecuteAsync">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    protected override async Task OnInitializedAsync() => await VM.InitializeCommand.ExecuteAsync(null);
}