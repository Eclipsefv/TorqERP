@page "/appointments"
@using TorqERP.ViewModels
@using TorqERP.DataModels
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AppointmentsViewModel VM

<MudText Typo="Typo.h4" Class="mb-4" Color="Color.Primary">Appointments</MudText>

<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Color="Color.Primary" OnClick="VM.PreviousMonth" />
            <MudText Typo="Typo.h6" Style="min-width:180px; text-align:center;">@VM.CurrentMonthLabel</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Primary" OnClick="VM.NextMonth" />
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudChip T="string" Icon="@Icons.Material.Filled.Schedule" Color="Color.Primary" Variant="Variant.Text" Size="Size.Small">
                @VM.Appointments.Count(a => a.Status == "SCHEDULED") Scheduled
            </MudChip>
            <MudChip T="string" Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Variant="Variant.Text" Size="Size.Small">
                @VM.Appointments.Count(a => a.Status == "COMPLETED") Completed
            </MudChip>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Today"
                       OnClick="VM.GoToToday" Size="Size.Small">Today</MudButton>
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Default"
                           OnClick="VM.LoadAppointmentsCommand.ExecuteAsync" />
        </MudStack>
    </MudStack>
</MudPaper>

@if (VM.IsLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-3" />
}

<MudGrid Spacing="3">
    <MudItem xs="12" md="@(VM.IsDetailsPanelOpen ? 8 : 12)">
        <MudPaper Elevation="2" Class="pa-4">
            <div class="appt-calendar-grid mb-2">
                @foreach (var header in VM.GetWeekDayHeaders())
                {
                    <div class="appt-day-header">@header</div>
                }
            </div>
            <div class="appt-calendar-grid">
                @foreach (var day in VM.GetCalendarDays())
                {
                    @if (day is null)
                    {
                        <div class="appt-day-empty"></div>
                    }
                    else
                    {
                        var hasAppts = VM.HasAppointments(day.Value);
                        var count = VM.AppointmentCount(day.Value);
                        var isToday = VM.IsToday(day.Value);
                        var isSelected = VM.IsSelectedDay(day.Value);

                        <div class="@GetDayCellClass(isToday, isSelected, hasAppts)"
                             @onclick="() => VM.SelectDate(day.Value)">

                            @if (isToday)
                            {
                                <MudAvatar Color="Color.Primary" Size="Size.Small" Class="appt-day-number-today">
                                    @day.Value.Day
                                </MudAvatar>
                            }
                            else
                            {
                                <span class="@(isSelected ? "appt-day-number appt-day-number--selected" : "appt-day-number")">
                                    @day.Value.Day
                                </span>
                            }

                            @if (hasAppts)
                            {
                                <div class="appt-dot-row">
                                    @for (int i = 0; i < Math.Min(count, 3); i++)
                                    {
                                        <span class="appt-dot @(isSelected ? "appt-dot--selected" : "")"></span>
                                    }
                                    @if (count > 3)
                                    {
                                        <span class="appt-dot-more">+@(count - 3)</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </MudPaper>
    </MudItem>

    @if (VM.IsDetailsPanelOpen)
    {
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                    <div>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
                            @VM.SelectedDate?.ToString("dddd", System.Globalization.CultureInfo.GetCultureInfo("en-US"))
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @VM.SelectedDate?.ToString("dd MMMM yyyy", System.Globalization.CultureInfo.GetCultureInfo("en-US"))
                        </MudText>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="VM.CloseDetailsPanel" />
                </MudStack>

                <MudDivider Class="mb-3" />

                @if (!VM.SelectedDayAppointments.Any())
                {
                    <MudStack AlignItems="AlignItems.Center" Class="mt-6" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.body1" Color="Color.Secondary">No appointments this day</MudText>
                    </MudStack>
                }
                else
                {
                    @foreach (var appt in VM.SelectedDayAppointments)
                    {
                        <MudCard Elevation="1" Class="mb-3">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudIcon Icon="@VM.GetStatusIcon(appt.Status)"
                                             Color="@VM.GetStatusColor(appt.Status)" Size="Size.Medium" />
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.subtitle2">@appt.DisplayClient</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @appt.DisplayTime · @appt.DisplayVehicle
                                    </MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudChip T="string" Color="@VM.GetStatusColor(appt.Status)"
                                             Size="Size.Small" Variant="Variant.Filled">
                                        @VM.GetStatusLabel(appt.Status)
                                    </MudChip>
                                </CardHeaderActions>
                            </MudCardHeader>
                            @if (!string.IsNullOrWhiteSpace(appt.Description))
                            {
                                <MudCardContent Class="pt-0">
                                    <MudDivider Class="mb-2" />
                                    <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small"
                                                 Color="Color.Secondary" Style="margin-top:2px;" />
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@appt.Description</MudText>
                                    </MudStack>
                                </MudCardContent>
                            }
                        </MudCard>
                    }
                }
            </MudPaper>
        </MudItem>
    }
</MudGrid>

@code {
    protected override async Task OnInitializedAsync() => await VM.InitializeCommand.ExecuteAsync(null);

    private string GetDayCellClass(bool isToday, bool isSelected, bool hasAppts)
    {
        var cls = "appt-day-cell";
        if (isSelected) cls += " appt-day-cell--selected";
        else if (isToday) cls += " appt-day-cell--today";
        if (hasAppts) cls += " appt-day-cell--has-appts";
        return cls;
    }
}
