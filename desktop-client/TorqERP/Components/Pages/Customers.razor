@page "/customers"
@using TorqERP.ViewModels
@using TorqERP.DataModels
@using Microsoft.AspNetCore.Authorization
@using System.Linq
@attribute [Authorize]
@inject CustomersViewModel ViewModel

<MudText Typo="Typo.h4" Class="mb-4" Color="Color.Primary">Customer Management</MudText>

<MudTable Items="@ViewModel.Customers"
          Hover="true"
          Breakpoint="Breakpoint.Sm"
          Loading="@ViewModel.Loading"
          LoadingProgressColor="Color.Info"
          Filter="new Func<Customer,bool>(ViewModel.FilterCustomer)"
          Dense="true"
          OnRowClick="@((TableRowClickEventArgs<Customer> args) => ViewModel.OnRowClick(args.Item))"
          RowClass="cursor-pointer">

    <ToolBarContent>
        <MudText Typo="Typo.h6">Client List</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="ViewModel.SearchString"
                      Placeholder="Search by Name, NIF or Email"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium"
                      Class="mt-0" />
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ViewModel.OpenCreateDialog" StartIcon="@Icons.Material.Filled.Add">
            Add Customer
        </MudButton>
    </ToolBarContent>

    <HeaderContent>
        <MudTh>NIF</MudTh>
        <MudTh>Name</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Phone</MudTh>
        <MudTh>Address</MudTh>
        <MudTh>Vehicles</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd DataLabel="NIF">
            <MudText Typo="Typo.body2" Color="Color.Default"><b>@context.Nif</b></MudText>
        </MudTd>
        <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Email">@context.Email</MudTd>
            <MudTd DataLabel="Phone">@context.Phonenumber</MudTd>
            <MudTd DataLabel="Address">@(string.IsNullOrEmpty(context.Address) ? "-" : context.Address)</MudTd>
            <MudTd DataLabel="Vehicles">
                @if (context.Vehicles != null && context.Vehicles.Any())
            {
                <MudChip T="string" Variant="Variant.Text" Color="Color.Info" Size="Size.Small">
                    @context.Vehicles.Count Cars
                </MudChip>
            }
            else
            {
                <MudText Typo="Typo.caption" Color="Color.Default">None</MudText>
            }
        </MudTd>
    </RowTemplate>

    <PagerContent>
        <MudTablePager InfoFormat="{first_item}-{last_item} of {all_items}" RowsPerPageString="Rows per page:" />
    </PagerContent>
</MudTable>

<MudDialog @bind-Visible="ViewModel.IsDialogVisible" Options="ViewModel.DialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(ViewModel.IsEditMode ? Icons.Material.Filled.Edit : Icons.Material.Filled.PersonAdd)" Class="mr-3" />

            @if (ViewModel.ActiveTabIndex == 0)
            {
                @(ViewModel.IsEditMode ? $"Vehicles Overview: {ViewModel.CurrentCustomer.Name}" : "New Customer Vehicles")
            }
            else if (ViewModel.ActiveTabIndex == 1)
            {
                @(ViewModel.IsEditMode ? $"Edit Customer: {ViewModel.CurrentCustomer.Name}" : "New Customer")
            }
            else
            {
                @(ViewModel.IsEditMode ? $"WIP: {ViewModel.CurrentCustomer.Name}" : "WIP")
            }
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs @bind-ActivePanelIndex="ViewModel.ActiveTabIndex" Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">

            <MudTabPanel Text="Vehicles" Icon="@Icons.Material.Filled.DirectionsCar">
                @if (ViewModel.CurrentCustomer.Vehicles != null && ViewModel.CurrentCustomer.Vehicles.Any())
                {
                    <MudList T="Vehicle">
                        @foreach (var vehicle in ViewModel.CurrentCustomer.Vehicles)
                        {
                            <MudListItem Icon="@Icons.Material.Filled.DirectionsCar">
                                @vehicle.Brand @vehicle.Model (@vehicle.Plate)
                            </MudListItem>
                        }
                    </MudList>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Class="mt-4">This customer has no vehicles registered</MudAlert>
                }
            </MudTabPanel>

            <MudTabPanel Text="General Info" Icon="@Icons.Material.Filled.Info">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="NIF" @bind-Value="ViewModel.CurrentCustomer.Nif" Required="true" Variant="Variant.Outlined" Disabled="@ViewModel.IsEditMode" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Name" @bind-Value="ViewModel.CurrentCustomer.Name" Required="true" Variant="Variant.Outlined" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Email" @bind-Value="ViewModel.CurrentCustomer.Email" Variant="Variant.Outlined" InputType="InputType.Email" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Phone Number" @bind-Value="ViewModel.CurrentCustomer.Phonenumber" Variant="Variant.Outlined" InputType="InputType.Telephone" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField T="string" Label="Address" @bind-Value="ViewModel.CurrentCustomer.Address" Variant="Variant.Outlined" Lines="2" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        @if (ViewModel.ActiveTabIndex == 0)
        {
            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="ViewModel.CloseDialog">Close</MudButton>
        }
        else
        {
            <MudButton OnClick="ViewModel.CloseDialog">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ViewModel.SaveCustomerAsync">Save</MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    protected override async Task OnInitializedAsync()
    {
        await ViewModel.InitializeAsync();
    }
}
