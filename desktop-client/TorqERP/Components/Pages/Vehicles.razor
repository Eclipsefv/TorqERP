@page "/vehicles"
@using TorqERP.ViewModels
@using TorqERP.DataModels
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject VehiclesViewModel VM

<MudText Typo="Typo.h4" Class="mb-4" Color="Color.Primary">Vehicle Management</MudText>

<MudTable Items="VM.Vehicles"
          Loading="VM.IsLoading"
          LoadingProgressColor="Color.Info"
          Hover="true"
          Dense="true"
          Breakpoint="Breakpoint.Sm"
          Elevation="1"
          OnRowClick="@((TableRowClickEventArgs<Vehicle> args) => VM.OnRowClick(args))"
          RowClass="cursor-pointer"
          Filter="new Func<Vehicle, bool>(VM.FilterVehicle)">

    <ToolBarContent>
        <MudText Typo="Typo.h6">Registered Vehicles</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="VM.SearchString"
                      Placeholder="Search by plate, brand or model"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium"
                      Class="mt-0"
                      Immediate="true" />
        <MudSpacer />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="VM.OpenCreateDialog">
            Add Vehicle
        </MudButton>
    </ToolBarContent>

    <HeaderContent>
        <MudTh>Plate</MudTh>
        <MudTh>Brand</MudTh>
        <MudTh>Model</MudTh>
        <MudTh>Year</MudTh>
        <MudTh>Owner</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd DataLabel="Plate">
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Text" Size="Size.Small">@context.Plate</MudChip>
        </MudTd>
        <MudTd DataLabel="Brand">@context.Brand</MudTd>
        <MudTd DataLabel="Model">@context.Model</MudTd>
        <MudTd DataLabel="Year">@context.Year</MudTd>
        <MudTd DataLabel="Owner">@(context.Customer?.Name ?? "Unassigned")</MudTd>
    </RowTemplate>

    <PagerContent>
        <MudTablePager InfoFormat="{first_item}-{last_item} of {all_items}" RowsPerPageString="Rows per page:" />
    </PagerContent>
</MudTable>

<MudDialog @bind-Visible="VM.IsDialogVisible" Options="VM.DialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(VM.IsEditMode? Icons.Material.Filled.Edit : Icons.Material.Filled.DirectionsCar)" Class="mr-3" />
            @(VM.IsEditMode ? $"Edit vehicle: {VM.CurrentVehicle.Plate}" : "New vehicle")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudAutocomplete T="Customer"
                                 Label="Owner"
                                 @bind-Value="VM.SelectedCustomer"
                                 SearchFunc="VM.SearchCustomers"
                                 ToStringFunc="@(c => c == null ? null : $"{c.Name} ({c.Nif})")"
                                 Variant="Variant.Outlined"
                                 AdornmentIcon="@Icons.Material.Filled.Search"
                                 Placeholder="Type to search..." />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Plate" @bind-Value="VM.CurrentVehicle.Plate" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudNumericField T="int?" Label="Year" @bind-Value="VM.CurrentVehicle.Year" Variant="Variant.Outlined" Min="1900" Max="2100" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Brand" @bind-Value="VM.CurrentVehicle.Brand" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Model" @bind-Value="VM.CurrentVehicle.Model" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="VM.CloseDialog">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="VM.SaveVehicleCommand.ExecuteAsync">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    protected override async Task OnInitializedAsync()
    {
        await VM.InitializeCommand.ExecuteAsync(null);
    }
}